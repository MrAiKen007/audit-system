{
  "manifest_version": 1,
  "name": "Audit System",
  "id": "audit-system-security-plugin",
  "version": "1.0.0",
  "description": "Multi-agent smart contract security auditing framework with 8 specialized agents and comprehensive vulnerability discovery",
  "author": "Jorge Paim",
  "license": "MIT",
  "repository": "https://github.com/MrAiKen007/audit-system",
  "homepage": "https://github.com/MrAiKen007/audit-system#readme",
  "claude_code": {
    "min_version": "1.0.0",
    "max_version": "*"
  },
  "capabilities": [
    "security_analysis",
    "vulnerability_scanning",
    "exploit_generation",
    "automated_testing",
    "multi_agent_coordination"
  ],
  "categories": [
    "security",
    "blockchain",
    "smart-contracts",
    "auditing"
  ],
  "type": "plugin",
  "entry_point": "claude-plugin.json",
  "commands": {
    "audit-connect": {
      "description": "Connect audit-system to current project and activate all resources",
      "usage": "/audit-connect [--mode=full|novel|quick] [--target=./path] [--model=auto]"
    },
    "audit-agent": {
      "description": "Execute specific audit agent",
      "usage": "/audit-agent <agent-name> [--target=./path]"
    },
    "audit-status": {
      "description": "Show audit-system connection status",
      "usage": "/audit-status"
    },
    "audit-agents": {
      "description": "List all available audit agents",
      "usage": "/audit-agents"
    }
  },
  "installation": {
    "type": "git",
    "url": "https://github.com/MrAiKen007/audit-system.git",
    "setup": "npm install && npm run setup"
  },
  "requirements": {
    "node": ">=16.0.0",
    "claude_code": ">=1.0.0"
  },
  "resources": {
    "agents": 8,
    "skills": 5,
    "knowledge_base": "obsidian-vault (14+ files)",
    "supported_models": [
      "claude-opus-4-6",
      "claude-sonnet-4-6", 
      "claude-haiku-4-5",
      "kimi-k2.5",
      "kimi-k2",
      "gpt-4o",
      "gpt-4-turbo",
      "gemini-pro",
      "gemini-ultra",
      "local-models"
    ]
  }
}
